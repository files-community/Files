<Page
	x:Class="Files.App.UITests.Views.MenuFlyoutItemExPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:Files.App.UITests.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Background="Transparent"
	mc:Ignorable="d">

	<Grid Padding="36" RowSpacing="24">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Spacing="8">
			<TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="MenuFlyoutItemEx" />
			<TextBlock
				Foreground="{ThemeResource TextFillColorSecondaryBrush}"
				Style="{StaticResource CaptionTextBlockStyle}"
				Text="Files.App.Controls" />
		</StackPanel>

		<StackPanel Grid.Row="1" Spacing="24">
			<StackPanel Spacing="32">

				<DropDownButton Content="Standard Menu Flyout">
					<DropDownButton.Flyout>
						<MenuFlyout Placement="Bottom">
							<MenuFlyoutItem KeyboardAcceleratorTextOverride="Key Combo" Text="Standard Item">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="Send" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>
							<MenuFlyoutItem
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Standard Item Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReply" />
								</MenuFlyoutItem.Icon>
							</MenuFlyoutItem>

							<MenuFlyoutSeparator />
							<MenuFlyoutItem IsEnabled="False" Text="Radio Menu Items" />

							<RadioMenuFlyoutItem KeyboardAcceleratorTextOverride="Key Combo" Text="Radio Item Unchecked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>
							<RadioMenuFlyoutItem
								IsChecked="True"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Radio Item Checked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>

							<MenuFlyoutSeparator />

							<RadioMenuFlyoutItem
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Radio Item Unchecked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>
							<RadioMenuFlyoutItem
								IsChecked="True"
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Radio Item Checked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>

							<MenuFlyoutSeparator />
							<MenuFlyoutItem IsEnabled="False" Text="Toggle Menu Items" />

							<ToggleMenuFlyoutItem KeyboardAcceleratorTextOverride="Key Combo" Text="Toggle Item Unchecked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
							<ToggleMenuFlyoutItem
								IsChecked="True"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Toggle Item Checked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>

							<MenuFlyoutSeparator />

							<ToggleMenuFlyoutItem
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Toggle Item Unchecked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
							<ToggleMenuFlyoutItem
								IsChecked="True"
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Toggle Item Checked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
						</MenuFlyout>
					</DropDownButton.Flyout>
				</DropDownButton>

				<DropDownButton Content="MenuEx Flyout">
					<DropDownButton.Flyout>
						<MenuFlyout Placement="Bottom">
							<controls:MenuFlyoutItemEx
								IconSize="16"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Standard Item"
								ThemedIcon="{StaticResource App.ThemedIcons.Settings.Experimental}" />
							<controls:MenuFlyoutItemEx
								IconSize="16"
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Standard Item Disabled"
								ThemedIcon="{StaticResource App.ThemedIcons.Settings.Experimental}" />

							<MenuFlyoutSeparator />
							<MenuFlyoutItem IsEnabled="False" Text="Radio Menu Items" />

							<RadioMenuFlyoutItem KeyboardAcceleratorTextOverride="Key Combo" Text="Radio Item Unchecked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>
							<RadioMenuFlyoutItem
								IsChecked="True"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Radio Item Checked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>

							<MenuFlyoutSeparator />

							<RadioMenuFlyoutItem
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Radio Item Unchecked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>
							<RadioMenuFlyoutItem
								IsChecked="True"
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Radio Item Checked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</RadioMenuFlyoutItem>

							<MenuFlyoutSeparator />
							<MenuFlyoutItem IsEnabled="False" Text="Toggle Menu Items" />

							<ToggleMenuFlyoutItem KeyboardAcceleratorTextOverride="Key Combo" Text="Toggle Item Unchecked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
							<ToggleMenuFlyoutItem
								IsChecked="True"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Toggle Item Checked">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>

							<MenuFlyoutSeparator />

							<ToggleMenuFlyoutItem
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Toggle Item Unchecked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
							<ToggleMenuFlyoutItem
								IsChecked="True"
								IsEnabled="False"
								KeyboardAcceleratorTextOverride="Key Combo"
								Text="Toggle Item Checked Disabled">
								<MenuFlyoutItem.Icon>
									<SymbolIcon Symbol="MailReplyAll" />
								</MenuFlyoutItem.Icon>
							</ToggleMenuFlyoutItem>
						</MenuFlyout>
					</DropDownButton.Flyout>
				</DropDownButton>

			</StackPanel>
		</StackPanel>
	</Grid>
</Page>
