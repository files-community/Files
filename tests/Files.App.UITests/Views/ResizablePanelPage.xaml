<Page
	x:Class="Files.App.UITests.Views.ResizablePanelPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<StackPanel Spacing="24">

		<controls:SamplePanel Header="Default usage (horizontal)">
			<controls:SamplePanel.MainContent>

				<controls:ResizablePanel Height="48" HorizontalAlignment="Left">
					<Rectangle
						x:Name="R1"
						Width="200"
						MinWidth="64"
						Fill="Blue"
						Opacity="0.5" />
					<Rectangle
						x:Name="R2"
						Width="200"
						MinWidth="64"
						Fill="Green"
						Opacity="0.5" />
					<Rectangle
						x:Name="R3"
						Width="200"
						MinWidth="64"
						Fill="Red"
						Opacity="0.5" />
				</controls:ResizablePanel>

			</controls:SamplePanel.MainContent>
		</controls:SamplePanel>

		<controls:SamplePanel Header="Vertical stacking">
			<controls:SamplePanel.MainContent>

				<controls:ResizablePanel
					Width="200"
					VerticalAlignment="Top"
					Orientation="Vertical">
					<Rectangle
						x:Name="V1"
						Height="100"
						MinHeight="48"
						Fill="Blue"
						Opacity="0.5" />
					<Rectangle
						x:Name="V2"
						Height="100"
						MinHeight="48"
						Fill="Green"
						Opacity="0.5" />
					<Rectangle
						x:Name="V3"
						Height="100"
						MinHeight="48"
						Fill="Red"
						Opacity="0.5" />
				</controls:ResizablePanel>

			</controls:SamplePanel.MainContent>
		</controls:SamplePanel>

	</StackPanel>
</Page>
