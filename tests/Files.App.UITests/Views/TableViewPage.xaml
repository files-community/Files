<Page
	x:Class="Files.App.UITests.Views.TableViewPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:data="using:Files.App.UITests.Data"
	xmlns:local="using:Files.App.UITests.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:selectors="using:Files.App.UITests.Views.TemplateSelectors"
	Loaded="TableViewPage_Loaded"
	mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary>

					<!--<Style x:Key="TableViewListViewStyle" TargetType="ListView">
						<Style.Setters>
							<Setter Property="Margin" Value="-4,0" />
						</Style.Setters>
					</Style>-->

					<Style
						x:Key="TableViewListViewItemStyle"
						BasedOn="{StaticResource DefaultListViewItemStyle}"
						TargetType="ListViewItem">
						<Style.Setters>
							<Setter Property="Padding" Value="4,0" />
							<Setter Property="VerticalAlignment" Value="Stretch" />
							<Setter Property="VerticalContentAlignment" Value="Stretch" />
						</Style.Setters>
					</Style>

					<DataTemplate x:Key="TextTableViewColumnTemplate" x:DataType="data:TableViewColumnModel">
						<controls:TableViewTextColumn
							Binding="{Binding PropertyName}"
							ColumnWidth="240"
							Header="{Binding Header}" />
					</DataTemplate>

					<DataTemplate x:Key="DateTableViewColumnTemplate" x:DataType="data:TableViewColumnModel">
						<controls:TableViewDateColumn
							Binding="{Binding PropertyName}"
							ColumnWidth="240"
							Header="{Binding Header}" />
					</DataTemplate>

					<selectors:TableViewColumnTemplateSelector
						x:Key="TableViewColumnTemplateSelector"
						DateColumnTemplate="{StaticResource DateTableViewColumnTemplate}"
						TextColumnTemplate="{StaticResource TextTableViewColumnTemplate}" />

					<data:NegatedBooleanToVisibilityConverter x:Key="NegatedBooleanToVisibilityConverter" />

					<DataTemplate x:Key="DetailsFileIconCellTemplate" x:DataType="data:DetailsViewItemModel">
						<FontIcon
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							FontSize="16"
							Glyph="{x:Bind IconGlyph, Mode=OneWay}" />
					</DataTemplate>

					<DataTemplate x:Key="ToolbarActionCellTemplate" x:DataType="data:ToolbarCustomizationItemModel">
						<Grid>
							<TextBlock
								Margin="8,0,0,0"
								VerticalAlignment="Center"
								FontSize="16"
								Text="&#x2807;" />
							<TextBlock
								Margin="32,0,8,0"
								VerticalAlignment="Center"
								Text="{x:Bind DisplayName}"
								TextTrimming="CharacterEllipsis" />
						</Grid>
					</DataTemplate>

					<DataTemplate x:Key="ToolbarRemoveCellTemplate" x:DataType="data:ToolbarCustomizationItemModel">
						<Button
							Width="32"
							Height="24"
							Padding="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							AutomationProperties.Name="Remove"
							Background="Transparent"
							BorderThickness="0"
							Click="RemoveToolbarItem_Click"
							ToolTipService.ToolTip="Remove">
							<FontIcon FontSize="12" Glyph="&#xE711;" />
						</Button>
					</DataTemplate>

					<Style
						x:Key="DetailsListViewItemStyle"
						BasedOn="{StaticResource DefaultListViewItemStyle}"
						TargetType="ListViewItem">
						<Setter Property="MinHeight" Value="36" />
						<Setter Property="Padding" Value="4,0" />
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
						<Setter Property="VerticalContentAlignment" Value="Stretch" />
					</Style>

					<Style
						x:Key="ToolbarListViewItemStyle"
						BasedOn="{StaticResource DefaultListViewItemStyle}"
						TargetType="ListViewItem">
						<Setter Property="MinHeight" Value="40" />
						<Setter Property="Margin" Value="0" />
						<Setter Property="Padding" Value="0" />
						<Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
						<Setter Property="BorderThickness" Value="0,0,0,1" />
						<Setter Property="HorizontalContentAlignment" Value="Stretch" />
						<Setter Property="VerticalContentAlignment" Value="Stretch" />
					</Style>

				</ResourceDictionary>
			</ResourceDictionary.MergedDictionaries>
		</ResourceDictionary>
	</Page.Resources>

	<StackPanel Spacing="24">

		<controls:SamplePanel Header="Default usage">
			<controls:SamplePanel.MainContent>
				<Grid>

					<!--<controls:DragSelectionContainer Height="700">
						<controls:DragSelectionContainer.Targets>
							<controls:DragSelectionTarget Target="{x:Bind Sample1ListView1}" />
						</controls:DragSelectionContainer.Targets>-->

					<ContentControl x:Name="SourceTableHost">
						<controls:TableView
							x:Name="SourceTableView"
							Grid.Row="1"
							Height="440"
							VerticalAlignment="Top"
							BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
							BorderThickness="1"
							ColumnTemplateSelector="{StaticResource TableViewColumnTemplateSelector}"
							ColumnsSource="{x:Bind Columns, Mode=OneWay}"
							Sorting="TableView_Sorting">

							<controls:TableView.View>
								<ListView
									x:Name="Sample1ListView1"
									ItemContainerStyle="{StaticResource TableViewListViewItemStyle}"
									ItemsSource="{x:Bind Items, Mode=OneWay}">
									<ListView.ItemTemplate>
										<DataTemplate x:DataType="data:TableViewItemModel">
											<controls:TableViewRow HorizontalAlignment="Stretch" />
										</DataTemplate>
									</ListView.ItemTemplate>
								</ListView>
							</controls:TableView.View>

						</controls:TableView>
					</ContentControl>

					<!--</controls:DragSelectionContainer>-->

				</Grid>
			</controls:SamplePanel.MainContent>
			<controls:SamplePanel.SideContent>
				<StackPanel Spacing="12">
					<Button Click="ToggleSourceTable_Click" Content="Detach or reattach table" />
					<Button Click="UpdateFirstItem_Click" Content="Update first item" />
					<Button Click="AddOrRemoveColumn_Click" Content="Add or remove column" />
					<TextBlock x:Name="SortStatusTextBlock" Text="Not sorted" />
				</StackPanel>
			</controls:SamplePanel.SideContent>
		</controls:SamplePanel>

		<controls:SamplePanel Header="Declared Columns usage">
			<controls:SamplePanel.MainContent>
				<controls:TableView Height="280" Sorting="TableView_Sorting">
					<controls:TableView.Columns>
						<controls:TableViewTextColumn
							Binding="Name"
							ColumnWidth="2*"
							Header="Name" />
						<controls:TableViewDateColumn
							Binding="DateUpdated"
							ColumnWidth="Auto"
							Header="Date updated" />
						<controls:TableViewTextColumn
							Binding="Type"
							ColumnWidth="*"
							Header="Type" />
					</controls:TableView.Columns>
					<controls:TableView.View>
						<ListView ItemContainerStyle="{StaticResource TableViewListViewItemStyle}" ItemsSource="{x:Bind Items, Mode=OneWay}">
							<ListView.ItemTemplate>
								<DataTemplate x:DataType="data:TableViewItemModel">
									<controls:TableViewRow HorizontalAlignment="Stretch" />
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</controls:TableView.View>
				</controls:TableView>
			</controls:SamplePanel.MainContent>
		</controls:SamplePanel>

		<controls:SamplePanel Header="Details view scenario">
			<controls:SamplePanel.MainContent>
				<controls:TableView
					Height="520"
					BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
					BorderThickness="1"
					CornerRadius="8"
					Sorting="DetailsTable_Sorting">
					<controls:TableView.Columns>
						<controls:TableViewTemplateColumn
							CanUserResize="False"
							CanUserSort="False"
							CellTemplate="{StaticResource DetailsFileIconCellTemplate}"
							ColumnWidth="40"
							Header="" />
						<controls:TableViewTextColumn
							Binding="Name"
							ColumnWidth="2*"
							Header="Name"
							MinWidth="180" />
						<controls:TableViewDateColumn
							Binding="DateModified"
							ColumnWidth="Auto"
							Header="Date modified"
							IsReadOnly="True"
							MinWidth="160" />
						<controls:TableViewTextColumn
							Binding="Type"
							ColumnWidth="220"
							Header="Type"
							IsReadOnly="True" />
						<controls:TableViewTextColumn
							Binding="Size"
							ColumnWidth="110"
							Header="Size"
							IsReadOnly="True" />
					</controls:TableView.Columns>
					<controls:TableView.View>
						<ListView
							ItemContainerStyle="{StaticResource DetailsListViewItemStyle}"
							ItemsSource="{x:Bind DetailsItems, Mode=OneWay}"
							SelectionMode="Extended">
							<ListView.ItemTemplate>
								<DataTemplate x:DataType="data:DetailsViewItemModel">
									<controls:TableViewRow HorizontalAlignment="Stretch" />
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</controls:TableView.View>
				</controls:TableView>
			</controls:SamplePanel.MainContent>
		</controls:SamplePanel>

		<controls:SamplePanel Header="Toolbar customization dialog scenario">
			<controls:SamplePanel.MainContent>
				<controls:TableView
					x:Name="ToolbarItemsTable"
					Height="360"
					HorizontalAlignment="Left"
					Background="{ThemeResource LayerFillColorDefaultBrush}"
					BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
					BorderThickness="1"
					CanUserReorderColumns="False"
					CanUserSortColumns="False"
					CornerRadius="8">
					<controls:TableView.Resources>
						<x:Double x:Key="TableViewColumnHeaderHeight">32</x:Double>
						<x:Double x:Key="ResizeVisualIndicatorHeight">24</x:Double>
					</controls:TableView.Resources>
					<controls:TableView.Columns>
						<controls:TableViewTemplateColumn CellTemplate="{StaticResource ToolbarActionCellTemplate}" ColumnWidth="270" Header="Action" />
						<controls:TableViewCheckBoxColumn
							Binding="ShowIcon"
							ColumnWidth="64"
							Header="Icon"
							IsEnabledBinding="HasIcon"
							VisibilityBinding="IsSeparator"
							VisibilityConverter="{StaticResource NegatedBooleanToVisibilityConverter}" />
						<controls:TableViewCheckBoxColumn
							Binding="ShowLabel"
							ColumnWidth="68"
							Header="Label"
							VisibilityBinding="IsSeparator"
							VisibilityConverter="{StaticResource NegatedBooleanToVisibilityConverter}" />
						<controls:TableViewTemplateColumn
							CellTemplate="{StaticResource ToolbarRemoveCellTemplate}"
							ColumnWidth="44"
							Header=""
							MinWidth="44" />
					</controls:TableView.Columns>
					<controls:TableView.View>
						<ListView
							Padding="4"
							CanDragItems="True"
							CanReorderItems="True"
							ItemContainerStyle="{StaticResource ToolbarListViewItemStyle}"
							ItemsSource="{x:Bind ToolbarItems, Mode=OneWay}"
							ReorderMode="Enabled"
							SelectionMode="None">
							<ListView.ItemTemplate>
								<DataTemplate x:DataType="data:ToolbarCustomizationItemModel">
									<controls:TableViewRow HorizontalAlignment="Stretch" />
								</DataTemplate>
							</ListView.ItemTemplate>
						</ListView>
					</controls:TableView.View>
				</controls:TableView>
			</controls:SamplePanel.MainContent>
		</controls:SamplePanel>

	</StackPanel>
</Page>
