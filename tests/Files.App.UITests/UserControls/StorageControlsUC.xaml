<UserControl
	x:Class="Files.App.UITests.UserControls.StorageControlsUC"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:Files.App.UITests.UserControls"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:primitives="using:Files.App.Controls.Primitives"
	mc:Ignorable="d">

	<Grid
		x:Name="RootGrid"
		Padding="24"
		HorizontalAlignment="Stretch"
		VerticalAlignment="Stretch">

		<ScrollViewer HorizontalContentAlignment="Left" VerticalContentAlignment="Top">
			<StackPanel Spacing="12">

				<NumberBox
					x:Name="testWidth"
					Header="Width"
					SpinButtonPlacementMode="Inline"
					Value="100" />

				<NumberBox
					x:Name="testHeight"
					Header="Height"
					SpinButtonPlacementMode="Inline"
					Value="120" />

				<Slider
					x:Name="testSAngle"
					Header="StartAngle ( -180 to 180 )"
					Maximum="180"
					Minimum="-180"
					Value="-150" />

				<Slider
					x:Name="testMAngle"
					Header="MaxAngle ( -180 to 540 )"
					Maximum="540"
					Minimum="-180"
					Value="150" />

				<Slider
					x:Name="testValue"
					Header="Value ( -10 to 110 )"
					Maximum="110"
					Minimum="-10"
					SmallChange="{x:Bind ringTest1.SmallChange, Mode=TwoWay}"
					Value="50" />

				<StackPanel Orientation="Horizontal" Spacing="16">

					<Grid VerticalAlignment="Stretch">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<TextBlock
							Grid.Row="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Style="{ThemeResource CaptionTextBlockStyle}"
							Text="" />

						<TextBlock
							Grid.Row="1"
							VerticalAlignment="Center"
							Text="LeftToRight (default)" />

						<TextBlock
							Grid.Row="2"
							VerticalAlignment="Center"
							Text="RightToLeft" />

					</Grid>

					<Grid VerticalAlignment="Stretch">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<TextBlock
							Grid.Row="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Style="{ThemeResource CaptionTextBlockStyle}"
							Text="Default" />

						<controls:StorageRing
							x:Name="ringTest1"
							Grid.Row="1"
							Value="{x:Bind testValue.Value, Mode=TwoWay}" />

						<controls:StorageRing
							x:Name="ringTest1b"
							Grid.Row="2"
							FlowDirection="RightToLeft"
							Value="{x:Bind testValue.Value, Mode=TwoWay}" />

					</Grid>


					<Grid VerticalAlignment="Stretch">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>

						<TextBlock
							Grid.Row="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Style="{ThemeResource CaptionTextBlockStyle}"
							Text="Customised" />

						<controls:StorageRing
							x:Name="ringTest2"
							Grid.Row="1"
							Width="{x:Bind testWidth.Value, Mode=TwoWay}"
							Height="{x:Bind testHeight.Value, Mode=TwoWay}"
							Margin="12"
							Padding="12"
							BorderBrush="#33FFFF00"
							BorderThickness="1"
							Foreground="{ThemeResource SystemFillColorSuccessBrush}"
							Background="{ThemeResource DividerStrokeColorDefaultBrush}"
							MaxAngle="{x:Bind testMAngle.Value, Mode=TwoWay}"
							Maximum="100"
							MinAngle="{x:Bind testSAngle.Value, Mode=TwoWay}"
							Minimum="0"
							StartAngle="{x:Bind testSAngle.Value, Mode=TwoWay}"
							TrackRingThickness="5"
							ValueRingThickness="10"
							Value="{x:Bind testValue.Value, Mode=TwoWay}" />

						<controls:StorageRing
							x:Name="ringTest2b"
							Grid.Row="2"
							Width="{x:Bind testWidth.Value, Mode=TwoWay}"
							Height="{x:Bind testHeight.Value, Mode=TwoWay}"
							Margin="12"
							Padding="12"
							BorderBrush="#33FFFF00"
							BorderThickness="1"
							FlowDirection="RightToLeft"
							Foreground="{ThemeResource SystemFillColorSuccessBrush}"
							Background="{ThemeResource DividerStrokeColorDefaultBrush}"
							MaxAngle="{x:Bind testMAngle.Value, Mode=TwoWay}"
							Maximum="100"
							MinAngle="{x:Bind testSAngle.Value, Mode=TwoWay}"
							Minimum="0"
							StartAngle="{x:Bind testSAngle.Value, Mode=TwoWay}"
							TrackRingThickness="5"
							ValueRingThickness="10"
							Value="{x:Bind testValue.Value, Mode=TwoWay}" />

					</Grid>

				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</Grid>

</UserControl>
