<UserControl
	x:Class="Files.App.UserControls.TerminalPane"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:datamodels="using:Files.App.Data.Models"
	xmlns:helpers="using:Files.App.Helpers"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<UserControl.Resources>
		<ResourceDictionary>
			<Style x:Key="TerminalSidebarSplitterStyle" TargetType="controls:GridSplitter">
				<Setter Property="HorizontalAlignment" Value="Stretch" />
				<Setter Property="VerticalAlignment" Value="Stretch" />
				<Setter Property="MinWidth" Value="4" />
				<Setter Property="Background" Value="Transparent" />
				<Setter Property="GripperForeground" Value="Transparent" />
				<Setter Property="Template">
					<Setter.Value>
						<ControlTemplate TargetType="controls:GridSplitter">
							<Grid Background="Transparent" />
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
		</ResourceDictionary>
	</UserControl.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition x:Name="SidebarSplitterColumn" Width="Auto" />
			<ColumnDefinition
				x:Name="SidebarColumn"
				Width="200"
				MinWidth="120" />
		</Grid.ColumnDefinitions>

		<!--  Active terminal  -->
		<ContentPresenter Grid.Column="0" Content="{x:Bind MainPageViewModel.ActiveTerminal, Mode=OneWay}" />

		<!--  Resize splitter (cursor changes to resize arrow on hover; no visible line)  -->
		<controls:GridSplitter
			x:Name="SidebarSplitter"
			Grid.Column="1"
			ResizeBehavior="PreviousAndNext"
			ResizeDirection="Columns"
			Style="{StaticResource TerminalSidebarSplitterStyle}" />

		<!--  Right sidebar: toolbar + list of terminals  -->
		<Grid
			x:Name="TerminalSidebar"
			Grid.Column="2"
			Padding="0,0,0,4">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!--  Expanded toolbar: [chevron][+] ........... [...]  -->
			<Grid x:Name="ExpandedToolbar" Grid.Row="0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<!--  Left: chevron + add  -->
				<StackPanel
					Grid.Column="0"
					Orientation="Horizontal"
					Spacing="2">
					<Button
						Width="36"
						Height="36"
						Padding="0"
						AutomationProperties.Name="Toggle terminal list"
						Background="{ThemeResource AccentFillColorDefaultBrush}"
						BorderBrush="Transparent"
						Click="TerminalSidebarToggle_Click"
						Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
						ToolTipService.ToolTip="Toggle terminal list">
						<FontIcon FontSize="14" Glyph="&#xE76C;" />
					</Button>
					<Button
						Width="36"
						Height="36"
						Padding="0"
						AutomationProperties.Name="{helpers:ResourceString Name=NewTab}"
						Background="Transparent"
						BorderBrush="Transparent"
						ToolTipService.ToolTip="{helpers:ResourceString Name=NewTab}">
						<FontIcon FontSize="14" Glyph="&#xE710;" />
						<Button.Flyout>
							<Flyout Placement="Bottom">
								<ListView
									Margin="-12"
									Padding="4"
									DisplayMemberPath="Name"
									IsItemClickEnabled="True"
									ItemClick="TerminalProfile_ItemClick"
									ItemsSource="{x:Bind MainPageViewModel.TerminalProfiles, Mode=OneWay}"
									SelectionMode="None" />
							</Flyout>
						</Button.Flyout>
					</Button>
				</StackPanel>

				<!--  Right: more menu  -->
				<Button
					Grid.Column="2"
					Width="36"
					Height="36"
					Padding="0"
					AutomationProperties.Name="{helpers:ResourceString Name=MoreOptions}"
					Background="Transparent"
					BorderBrush="Transparent"
					ToolTipService.ToolTip="{helpers:ResourceString Name=MoreOptions}">
					<FontIcon FontSize="14" Glyph="&#xE712;" />
					<Button.Flyout>
						<MenuFlyout Placement="Bottom">
							<MenuFlyoutItem Command="{x:Bind MainPageViewModel.TerminalToggleCommand, Mode=OneWay}" Text="{helpers:ResourceString Name=Close}" />
						</MenuFlyout>
					</Button.Flyout>
				</Button>
			</Grid>

			<!--  Collapsed toolbar: chevron / + / ... stacked vertically  -->
			<StackPanel
				x:Name="CollapsedToolbar"
				Grid.Row="0"
				HorizontalAlignment="Center"
				Orientation="Vertical"
				Spacing="2"
				Visibility="Collapsed">
				<Button
					Width="36"
					Height="36"
					Padding="0"
					AutomationProperties.Name="Toggle terminal list"
					Background="Transparent"
					BorderBrush="Transparent"
					Click="TerminalSidebarToggle_Click"
					ToolTipService.ToolTip="Toggle terminal list">
					<FontIcon FontSize="14" Glyph="&#xE76B;" />
				</Button>
				<Button
					Width="36"
					Height="36"
					Padding="0"
					AutomationProperties.Name="{helpers:ResourceString Name=NewTab}"
					Background="Transparent"
					BorderBrush="Transparent"
					ToolTipService.ToolTip="{helpers:ResourceString Name=NewTab}">
					<FontIcon FontSize="14" Glyph="&#xE710;" />
					<Button.Flyout>
						<Flyout Placement="Bottom">
							<ListView
								Margin="-12"
								Padding="4"
								DisplayMemberPath="Name"
								IsItemClickEnabled="True"
								ItemClick="TerminalProfile_ItemClick"
								ItemsSource="{x:Bind MainPageViewModel.TerminalProfiles, Mode=OneWay}"
								SelectionMode="None" />
						</Flyout>
					</Button.Flyout>
				</Button>
				<Button
					Width="36"
					Height="36"
					Padding="0"
					AutomationProperties.Name="{helpers:ResourceString Name=MoreOptions}"
					Background="Transparent"
					BorderBrush="Transparent"
					ToolTipService.ToolTip="{helpers:ResourceString Name=MoreOptions}">
					<FontIcon FontSize="14" Glyph="&#xE712;" />
					<Button.Flyout>
						<MenuFlyout Placement="Bottom">
							<MenuFlyoutItem Command="{x:Bind MainPageViewModel.TerminalToggleCommand, Mode=OneWay}" Text="{helpers:ResourceString Name=Close}" />
						</MenuFlyout>
					</Button.Flyout>
				</Button>
			</StackPanel>

			<!--  Terminal list  -->
			<ListView
				x:Name="TerminalList"
				Grid.Row="1"
				Margin="0,4,0,0"
				Background="Transparent"
				ItemsSource="{x:Bind MainPageViewModel.Terminals, Mode=OneWay}"
				SelectedIndex="{x:Bind MainPageViewModel.SelectedTerminal, Mode=TwoWay}"
				SelectionMode="Single">
				<ListView.ItemTemplate>
					<DataTemplate x:DataType="datamodels:TerminalModel">
						<Grid ColumnSpacing="4">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<TextBlock
								Grid.Column="0"
								VerticalAlignment="Center"
								FontSize="12"
								Text="{x:Bind Name}"
								TextTrimming="CharacterEllipsis" />
							<Button
								Grid.Column="1"
								Width="20"
								Height="20"
								Padding="0"
								AutomationProperties.Name="{helpers:ResourceString Name=Close}"
								Background="Transparent"
								BorderBrush="Transparent"
								Click="TerminalListItemClose_Click"
								Tag="{x:Bind Id}"
								ToolTipService.ToolTip="{helpers:ResourceString Name=Close}">
								<FontIcon FontSize="10" Glyph="&#xE711;" />
							</Button>
						</Grid>
					</DataTemplate>
				</ListView.ItemTemplate>
			</ListView>
		</Grid>

		<VisualStateManager.VisualStateGroups>
			<VisualStateGroup x:Name="SidebarStates">
				<VisualState x:Name="ExpandedState">
					<VisualState.Setters>
						<Setter Target="TerminalSidebar.Padding" Value="0,0,0,4" />
						<Setter Target="SidebarSplitter.Visibility" Value="Visible" />
						<Setter Target="ExpandedToolbar.Visibility" Value="Visible" />
						<Setter Target="CollapsedToolbar.Visibility" Value="Collapsed" />
						<Setter Target="TerminalList.Visibility" Value="Visible" />
					</VisualState.Setters>
				</VisualState>
				<VisualState x:Name="CollapsedState">
					<VisualState.Setters>
						<Setter Target="TerminalSidebar.Padding" Value="4,0,4,4" />
						<Setter Target="SidebarSplitter.Visibility" Value="Collapsed" />
						<Setter Target="ExpandedToolbar.Visibility" Value="Collapsed" />
						<Setter Target="CollapsedToolbar.Visibility" Value="Visible" />
						<Setter Target="TerminalList.Visibility" Value="Collapsed" />
					</VisualState.Setters>
				</VisualState>
			</VisualStateGroup>
		</VisualStateManager.VisualStateGroups>
	</Grid>
</UserControl>
