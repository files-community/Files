<Page
	x:Class="Files.App.Views.Settings.ToolbarCustomizationPage"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="using:Files.App.Controls"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:dataitem="using:Files.App.Data.Items"
	xmlns:helpers="using:Files.App.Helpers"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:uc="using:Files.App.UserControls"
	xmlns:wctconverters="using:CommunityToolkit.WinUI.Converters"
	x:Name="PageRoot"
	mc:Ignorable="d">

	<Page.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="ms-appx:///Styles/ToolbarButtonStyle.xaml" />
			</ResourceDictionary.MergedDictionaries>

			<Style
				x:Key="HeaderTextStyle"
				BasedOn="{StaticResource App.Theme.CaptionTextBlockStyle}"
				TargetType="TextBlock">
				<Setter Property="FontWeight" Value="SemiBold" />
				<Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
				<Setter Property="TextWrapping" Value="NoWrap" />
				<Setter Property="VerticalAlignment" Value="Center" />
			</Style>

			<wctconverters:BoolToVisibilityConverter
				x:Key="NegatedBoolToVisibilityConverter"
				FalseValue="Visible"
				TrueValue="Collapsed" />
			<SolidColorBrush x:Key="CommandBarBackground" Color="Transparent" />
			<SolidColorBrush x:Key="CommandBarBackgroundOpen" Color="Transparent" />
			<SolidColorBrush x:Key="CommandBarBorderBrushOpen" Color="Transparent" />
			<x:Double x:Key="TableViewColumnHeaderHeight">32</x:Double>
			<x:Double x:Key="ResizeVisualIndicatorHeight">16</x:Double>
		</ResourceDictionary>
	</Page.Resources>

	<Grid RowSpacing="0">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!--  Title bar  -->
		<Grid
			x:Name="WindowTitleBar"
			Height="36"
			Padding="12,0,160,0"
			Background="Transparent">
			<TextBlock
				VerticalAlignment="Center"
				Style="{StaticResource App.Theme.CaptionTextBlockStyle}"
				Text="{helpers:ResourceString Name=CustomizeToolbar}" />
		</Grid>

		<!--  Context picker  -->
		<Grid Grid.Row="1" Padding="16,12">
			<StackPanel
				x:Name="ContextPickerPanel"
				Orientation="Horizontal"
				Spacing="12">
				<TextBlock
					x:Name="ToolbarModeLabel"
					VerticalAlignment="Center"
					Text="{helpers:ResourceString Name=ChooseToolbarModeToCustomize}"
					TextWrapping="WrapWholeWords" />
				<uc:ComboBoxEx
					x:Name="ToolbarModeComboBox"
					Width="240"
					HorizontalAlignment="Left"
					AutomationProperties.Name="{helpers:ResourceString Name=ChooseToolbarModeToCustomize}"
					DisplayMemberPath="Value"
					ItemsSource="{x:Bind ViewModel.ToolbarContexts, Mode=OneWay}"
					SelectedValue="{x:Bind ViewModel.SelectedToolbarContextId, Mode=TwoWay}"
					SelectedValuePath="Key" />
			</StackPanel>
		</Grid>

		<!--  Available and Added items  -->
		<Grid
			Grid.Row="2"
			Padding="16,12"
			ColumnSpacing="12">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="240" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<TextBlock
				Margin="4,0,0,8"
				Style="{StaticResource HeaderTextStyle}"
				Text="{helpers:ResourceString Name=AvailableToolbarItems}" />
			<TextBlock
				Grid.Column="1"
				Margin="4,0,0,8"
				Style="{StaticResource HeaderTextStyle}"
				Text="{helpers:ResourceString Name=AddedToolbarItems}" />

			<!--  Available items search + tree  -->
			<Grid
				Grid.Row="1"
				Grid.Column="0"
				RowSpacing="8">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<TextBox
					x:Name="AvailableToolbarItemsSearchBox"
					PlaceholderText="{helpers:ResourceString Name=Search}"
					Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				<Border
					Grid.Row="1"
					Background="{ThemeResource LayerFillColorDefaultBrush}"
					BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
					BorderThickness="1"
					CornerRadius="8">
					<ScrollViewer
						Padding="0,4,0,4"
						HorizontalScrollBarVisibility="Auto"
						HorizontalScrollMode="Enabled"
						VerticalScrollBarVisibility="Auto"
						VerticalScrollMode="Enabled">
						<TreeView
							AllowDrop="False"
							CanDragItems="True"
							DragItemsCompleted="AvailableToolbarItemsTree_DragItemsCompleted"
							DragItemsStarting="AvailableToolbarItemsTree_DragItemsStarting"
							ItemInvoked="AvailableToolbarItemsTree_ItemInvoked"
							ItemsSource="{x:Bind ViewModel.AvailableToolbarTreeItems, Mode=OneWay}"
							SelectionMode="Single">
							<TreeView.ItemContainerStyle>
								<Style TargetType="TreeViewItem">
									<Setter Property="Padding" Value="0,0,8,0" />
								</Style>
							</TreeView.ItemContainerStyle>
							<TreeView.ItemTemplate>
								<DataTemplate x:DataType="dataitem:ToolbarAvailableTreeItem">
									<TreeViewItem ItemsSource="{x:Bind Children}">
										<TextBlock VerticalAlignment="Center" Text="{x:Bind DisplayName}" />
									</TreeViewItem>
								</DataTemplate>
							</TreeView.ItemTemplate>
						</TreeView>
					</ScrollViewer>
				</Border>
			</Grid>

			<!--  Added items list  -->
			<controls:TableView
				x:Name="ToolbarItemsTable"
				Grid.Row="1"
				Grid.Column="1"
				HorizontalAlignment="Left"
				CanUserReorderColumns="False"
				CanUserSortColumns="False">
				<controls:TableView.Resources>
					<DataTemplate x:Key="ToolbarItemActionCellTemplate">
						<Grid>
							<PathIcon
								Margin="4,0,0,0"
								HorizontalAlignment="Left"
								VerticalAlignment="Center"
								Data="{StaticResource App.Theme.PathIcon.DragGripper}" />
							<TextBlock
								Margin="24,0,8,0"
								VerticalAlignment="Center"
								Text="{Binding ExtendedDisplayNameWithGroupSuffix}"
								TextTrimming="CharacterEllipsis"
								TextWrapping="NoWrap"
								ToolTipService.ToolTip="{Binding ExtendedDisplayNameWithGroupSuffix}" />
						</Grid>
					</DataTemplate>
					<DataTemplate x:Key="ToolbarItemRemoveCellTemplate">
						<Button
							Width="32"
							Height="24"
							Padding="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							AutomationProperties.Name="{helpers:ResourceString Name=Remove}"
							Background="Transparent"
							BorderThickness="0"
							Command="{Binding ElementName=PageRoot, Path=DataContext.RemoveToolbarItemCommand}"
							CommandParameter="{Binding}"
							ToolTipService.ToolTip="{helpers:ResourceString Name=Remove}">
							<Button.Resources>
								<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{ThemeResource SystemFillColorCritical}" />
								<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource SubtleFillColorSecondary}" />
							</Button.Resources>
							<FontIcon FontSize="12" Glyph="&#xE711;" />
						</Button>
					</DataTemplate>
				</controls:TableView.Resources>
				<controls:TableView.Columns>
					<controls:TableViewTemplateColumn
						CellTemplate="{StaticResource ToolbarItemActionCellTemplate}"
						ColumnWidth="270"
						Header="{helpers:ResourceString Name=Action}" />
					<controls:TableViewCheckBoxColumn
						MinWidth="64"
						Binding="ShowIcon"
						ColumnWidth="64"
						Header="{helpers:ResourceString Name=Icon}"
						IsEnabledBinding="HasIcon"
						VisibilityBinding="IsSeparator"
						VisibilityConverter="{StaticResource NegatedBoolToVisibilityConverter}" />
					<controls:TableViewCheckBoxColumn
						MinWidth="68"
						Binding="ShowLabel"
						ColumnWidth="68"
						Header="{helpers:ResourceString Name=Label}"
						VisibilityBinding="IsSeparator"
						VisibilityConverter="{StaticResource NegatedBoolToVisibilityConverter}" />
					<controls:TableViewTemplateColumn
						MinWidth="48"
						CellTemplate="{StaticResource ToolbarItemRemoveCellTemplate}"
						ColumnWidth="48"
						Header="" />
				</controls:TableView.Columns>
				<controls:TableView.View>
					<ListView
						x:Name="ToolbarItemsList"
						Padding="4"
						AllowDrop="True"
						CanDragItems="True"
						CanReorderItems="True"
						DragOver="AddedToolbarItemsList_DragOver"
						Drop="AddedToolbarItemsList_Drop"
						ItemsSource="{x:Bind ViewModel.ToolbarItems, Mode=OneWay}"
						ReorderMode="Enabled"
						ScrollViewer.HorizontalScrollBarVisibility="Auto"
						ScrollViewer.HorizontalScrollMode="Enabled"
						ScrollViewer.VerticalScrollBarVisibility="Auto"
						ScrollViewer.VerticalScrollMode="Enabled"
						SelectionMode="None">
						<ListView.ItemTemplate>
							<DataTemplate>
								<controls:TableViewRow HorizontalAlignment="Stretch" />
							</DataTemplate>
						</ListView.ItemTemplate>
						<ListView.ItemContainerStyle>
							<Style TargetType="ListViewItem">
								<Setter Property="Margin" Value="0" />
								<Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
								<Setter Property="BorderThickness" Value="0,0,0,1" />
								<Setter Property="Padding" Value="0" />
								<Setter Property="MinHeight" Value="40" />
								<Setter Property="HorizontalAlignment" Value="Stretch" />
								<Setter Property="HorizontalContentAlignment" Value="Stretch" />
							</Style>
						</ListView.ItemContainerStyle>
					</ListView>
				</controls:TableView.View>
			</controls:TableView>
		</Grid>

		<!--  Preview  -->
		<Grid
			Grid.Row="3"
			Margin="16,0"
			Padding="12"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
			BorderThickness="1"
			CornerRadius="8">
			<ScrollViewer
				HorizontalScrollBarVisibility="Auto"
				HorizontalScrollMode="Enabled"
				VerticalScrollBarVisibility="Disabled"
				VerticalScrollMode="Disabled">
				<CommandBar
					x:Name="PreviewCommandBar"
					HorizontalAlignment="Center"
					DefaultLabelPosition="Right"
					IsDynamicOverflowEnabled="False" />
			</ScrollViewer>
		</Grid>

		<!--  Actions  -->
		<Grid
			Grid.Row="4"
			Padding="16,12"
			ColumnSpacing="12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Button Command="{x:Bind ViewModel.ResetToolbarCommand, Mode=OneWay}" Content="{helpers:ResourceString Name=ResetDefaults}" />
			<StackPanel
				Grid.Column="2"
				Orientation="Horizontal"
				Spacing="8">
				<Button
					MinWidth="96"
					Command="{x:Bind ViewModel.SaveToolbarCommand, Mode=OneWay}"
					Content="{helpers:ResourceString Name=Save}"
					IsEnabled="{x:Bind ViewModel.HasToolbarChanges, Mode=OneWay}"
					Style="{StaticResource AccentButtonStyle}" />
				<Button
					MinWidth="96"
					Command="{x:Bind ViewModel.CancelToolbarCommand, Mode=OneWay}"
					Content="{helpers:ResourceString Name=Cancel}" />
			</StackPanel>
		</Grid>
		<VisualStateManager.VisualStateGroups>
			<VisualStateGroup>
				<VisualState x:Name="DefaultContextPickerState">
					<VisualState.StateTriggers>
						<AdaptiveTrigger MinWindowWidth="640" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="ContextPickerPanel.Orientation" Value="Horizontal" />
						<Setter Target="ContextPickerPanel.Spacing" Value="12" />
					</VisualState.Setters>
				</VisualState>
				<VisualState x:Name="CompactContextPickerState">
					<VisualState.StateTriggers>
						<AdaptiveTrigger MinWindowWidth="0" />
					</VisualState.StateTriggers>
					<VisualState.Setters>
						<Setter Target="ContextPickerPanel.Orientation" Value="Vertical" />
						<Setter Target="ContextPickerPanel.Spacing" Value="8" />
					</VisualState.Setters>
				</VisualState>
			</VisualStateGroup>
		</VisualStateManager.VisualStateGroups>
	</Grid>
</Page>
