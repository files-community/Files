<ResourceDictionary
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
	xmlns:local="using:Files.App.Controls"
	xmlns:wctcontrols="using:CommunityToolkit.WinUI.Controls">

	<ResourceDictionary.ThemeDictionaries>

		<ResourceDictionary x:Key="Default">
			<StaticResource x:Key="TableViewColumnBorderBrush" ResourceKey="ControlElevationBorderBrush" />
			<StaticResource x:Key="TableViewColumnBackground" ResourceKey="ControlFillColorTransparentBrush" />
		</ResourceDictionary>

		<ResourceDictionary x:Key="Dark">
			<StaticResource x:Key="TableViewColumnBorderBrush" ResourceKey="ControlElevationBorderBrush" />
			<StaticResource x:Key="TableViewColumnBackground" ResourceKey="ControlFillColorTransparentBrush" />
		</ResourceDictionary>

		<ResourceDictionary x:Key="HighContrast">
			<StaticResource x:Key="TableViewColumnBorderBrush" ResourceKey="ControlElevationBorderBrush" />
			<StaticResource x:Key="TableViewColumnBackground" ResourceKey="ControlFillColorTransparentBrush" />
		</ResourceDictionary>

	</ResourceDictionary.ThemeDictionaries>

	<Thickness x:Key="TableViewColumnBorderThickness">1</Thickness>
	<StaticResource x:Key="TableViewColumnCornerRadius" ResourceKey="ControlCornerRadius" />
	<x:Double x:Key="TableViewColumnHeaderHeight">44</x:Double>
	<x:Double x:Key="TableViewColumnResizeVisualWidth">16</x:Double>
	<GridLength x:Key="TableViewColumnResizeVisualOverflow">8</GridLength>
	<x:Double x:Key="SortOrderGlyphSize">8</x:Double>
	<x:String x:Key="SortOrderGlyph">&#xEDDB;</x:String>

	<DataTemplate x:Key="DefaultTableViewTextCellTemplate">
		<TextBlock />
	</DataTemplate>

	<Style x:Key="DefaultTableViewColumnHeaderStyle" TargetType="ContentPresenter">
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Center" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
		<Setter Property="TextWrapping" Value="NoWrap" />
	</Style>

	<Style BasedOn="{StaticResource DefaultTableViewStyle}" TargetType="local:TableView" />
	<Style BasedOn="{StaticResource DefaultTableViewCellStyle}" TargetType="local:TableViewCell" />
	<Style BasedOn="{StaticResource DefaultTableViewColumnHeadersPresenterStyle}" TargetType="local:TableViewColumnHeadersPresenter" />
	<Style BasedOn="{StaticResource DefaultTableViewColumnStyle}" TargetType="local:TableViewColumn" />
	<Style BasedOn="{StaticResource DefaultTableViewColumnStyle}" TargetType="local:TableViewTemplateColumn" />
	<Style BasedOn="{StaticResource DefaultTableViewCheckBoxColumnStyle}" TargetType="local:TableViewCheckBoxColumn" />
	<Style BasedOn="{StaticResource DefaultTableViewTextColumnStyle}" TargetType="local:TableViewTextColumn" />
	<Style BasedOn="{StaticResource DefaultTableViewDateColumnStyle}" TargetType="local:TableViewDateColumn" />

	<Style x:Key="DefaultTableViewStyle" TargetType="local:TableView">
		<Style.Setters>
			<Setter Property="Background" Value="{ThemeResource ControlFillColorTransparentBrush}" />
			<Setter Property="ColumnHeaderStyle" Value="{StaticResource DefaultTableViewColumnHeaderStyle}" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="BorderBrush" Value="{ThemeResource ControlElevationBorderBrush}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="local:TableView">
						<Border
							x:Name="PART_Root"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="{TemplateBinding CornerRadius}">
							<ContentPresenter
								x:Name="PART_ViewContentPresenter"
								Content="{TemplateBinding View}">
								<ContentPresenter.Resources>
									<ResourceDictionary />
								</ContentPresenter.Resources>
							</ContentPresenter>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style.Setters>
	</Style>

	<Style x:Key="DefaultTableViewColumnHeadersPresenterStyle" TargetType="local:TableViewColumnHeadersPresenter">
		<Setter Property="HorizontalAlignment" Value="Left" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:TableViewColumnHeadersPresenter">
					<Grid Margin="4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="{ThemeResource TableViewColumnResizeVisualOverflow}" />
						</Grid.ColumnDefinitions>
						<Border
							Grid.Column="0"
							Height="{ThemeResource TableViewColumnHeaderHeight}"
							Background="{ThemeResource TableViewColumnBackground}"
							BorderBrush="{ThemeResource TableViewColumnBorderBrush}"
							BorderThickness="{StaticResource TableViewColumnBorderThickness}"
							CornerRadius="{StaticResource TableViewColumnCornerRadius}">
							<local:ReorderableItemsControl x:Name="PART_ColumnsPanel" HorizontalAlignment="Left">
								<local:ReorderableItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<local:TableViewColumnResizePanel>
											<local:TableViewColumnResizePanel.Resources>
												<Style BasedOn="{StaticResource DefaultResizeVisualStyle}" TargetType="local:ResizeVisual">
													<Setter Property="Width" Value="{ThemeResource TableViewColumnResizeVisualWidth}" />
												</Style>
												<Style TargetType="Rectangle">
													<Setter Property="Width" Value="1" />
													<Setter Property="Fill" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
													<Setter Property="IsHitTestVisible" Value="False" />
												</Style>
											</local:TableViewColumnResizePanel.Resources>
										</local:TableViewColumnResizePanel>
									</ItemsPanelTemplate>
								</local:ReorderableItemsControl.ItemsPanel>
							</local:ReorderableItemsControl>
						</Border>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="DefaultTableViewCellStyle" TargetType="local:TableViewCell">
		<Setter Property="HorizontalContentAlignment" Value="Stretch" />
		<Setter Property="VerticalContentAlignment" Value="Stretch" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="local:TableViewCell">
					<Border
						x:Name="PART_CellBorder"
						Background="{TemplateBinding Background}"
						BorderBrush="Transparent"
						BorderThickness="0"
						ToolTipService.ToolTip="{TemplateBinding ValidationError}">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="ValidationStates">
								<VisualState x:Name="Valid" />
								<VisualState x:Name="ValidationError">
									<VisualState.Setters>
										<Setter Target="PART_CellBorder.BorderBrush" Value="{ThemeResource SystemFillColorCriticalBrush}" />
										<Setter Target="PART_CellBorder.BorderThickness" Value="1" />
									</VisualState.Setters>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
						<ContentPresenter
							HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
							VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
							Content="{TemplateBinding Content}" />
					</Border>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="DefaultTableViewColumnStyle" TargetType="local:TableViewColumn">
		<Style.Setters>
			<Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
			<Setter Property="VerticalAlignment" Value="Stretch" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
			<Setter Property="Padding" Value="16,0,16,0" />
			<Setter Property="MinWidth" Value="96" />
			<Setter Property="UseSystemFocusVisuals" Value="True" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="local:TableViewColumn">
						<Grid x:Name="PART_RootGrid" Background="{TemplateBinding Background}">
							<Grid.ColumnDefinitions>
								<ColumnDefinition x:Name="HeaderTextColumn" Width="*" />
								<ColumnDefinition x:Name="SortOrderGlyphColumn" Width="Auto" />
							</Grid.ColumnDefinitions>

							<ContentPresenter
								x:Name="PART_HeaderContentPresenter"
								Grid.Column="0"
								MinWidth="0"
								Margin="{TemplateBinding Padding}"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								ContentTemplate="{TemplateBinding HeaderTemplate}"
								ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" />

							<FontIcon
								x:Name="SortOrderGlyphTextBlock"
								Grid.Column="1"
								Margin="4,0,12,0"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								FontFamily="{ThemeResource SymbolThemeFontFamily}"
								FontSize="{StaticResource SortOrderGlyphSize}"
								Foreground="{ThemeResource TextFillColorTertiaryBrush}"
								Glyph="{StaticResource SortOrderGlyph}"
								RenderTransformOrigin="0.5,0.5"
								Visibility="Collapsed">
								<FontIcon.RenderTransform>
									<RotateTransform />
								</FontIcon.RenderTransform>
							</FontIcon>

							<VisualStateManager.VisualStateGroups>
								<VisualStateGroup x:Name="ColumnVisualStates">
									<VisualState x:Name="ColumnNormal" />
									<VisualState x:Name="ColumnPointerOver">
										<VisualState.Setters>
											<Setter Target="PART_RootGrid.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
											<Setter Target="PART_HeaderContentPresenter.Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
										</VisualState.Setters>
									</VisualState>
									<VisualState x:Name="ColumnPressed">
										<VisualState.Setters>
											<Setter Target="PART_RootGrid.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
											<Setter Target="PART_HeaderContentPresenter.Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
										</VisualState.Setters>
									</VisualState>
									<VisualState x:Name="ColumnDisabled">
										<VisualState.Setters>
											<Setter Target="PART_RootGrid.Background" Value="{ThemeResource ControlFillColorDisabledBrush}" />
											<Setter Target="PART_HeaderContentPresenter.Foreground" Value="{ThemeResource TextFillColorDisabledBrush}" />
										</VisualState.Setters>
									</VisualState>
								</VisualStateGroup>
								<VisualStateGroup x:Name="SortOrderVisualStates">
									<VisualState x:Name="SortOrderNone" />
									<VisualState x:Name="SortOrderAscending">
										<Storyboard>
											<DoubleAnimation
												Storyboard.TargetName="SortOrderGlyphTextBlock"
												Storyboard.TargetProperty="(FontIcon.RenderTransform).(RotateTransform.Angle)"
												To="0"
												Duration="0:0:0.12" />
										</Storyboard>
										<VisualState.Setters>
											<Setter Target="SortOrderGlyphTextBlock.Visibility" Value="Visible" />
										</VisualState.Setters>
									</VisualState>
									<VisualState x:Name="SortOrderDescending">
										<Storyboard>
											<DoubleAnimation
												Storyboard.TargetName="SortOrderGlyphTextBlock"
												Storyboard.TargetProperty="(FontIcon.RenderTransform).(RotateTransform.Angle)"
												To="-180"
												Duration="0:0:0.12" />
										</Storyboard>
										<VisualState.Setters>
											<Setter Target="SortOrderGlyphTextBlock.Visibility" Value="Visible" />
										</VisualState.Setters>
									</VisualState>
								</VisualStateGroup>
							</VisualStateManager.VisualStateGroups>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style.Setters>
	</Style>

	<Style
		x:Key="DefaultTableViewCheckBoxColumnStyle"
		BasedOn="{StaticResource DefaultTableViewColumnStyle}"
		TargetType="local:TableViewCheckBoxColumn">
		<Style.Setters>
			<Setter Property="ElementStyle" Value="{StaticResource DefaultTableViewCheckBoxStyle}" />
		</Style.Setters>
	</Style>

	<Style
		x:Key="DefaultTableViewTextColumnStyle"
		BasedOn="{StaticResource DefaultTableViewColumnStyle}"
		TargetType="local:TableViewTextColumn">
		<Style.Setters>
			<Setter Property="ElementStyle" Value="{StaticResource DefaultTableViewTextBlockStyle}" />
			<Setter Property="EditingElementStyle" Value="{StaticResource DefaultTableViewTextBoxStyle}" />
		</Style.Setters>
	</Style>

	<Style
		x:Key="DefaultTableViewDateColumnStyle"
		BasedOn="{StaticResource DefaultTableViewColumnStyle}"
		TargetType="local:TableViewDateColumn">
		<Style.Setters>
			<Setter Property="ElementStyle" Value="{StaticResource DefaultTableViewTextBlockStyle}" />
		</Style.Setters>
	</Style>

	<Style
		x:Key="DefaultTableViewCheckBoxStyle"
		BasedOn="{StaticResource DefaultCheckBoxStyle}"
		TargetType="CheckBox">
		<Style.Setters>
			<Setter Property="Width" Value="20" />
			<Setter Property="Height" Value="20" />
			<Setter Property="MinWidth" Value="0" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="Margin" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style.Setters>
	</Style>

	<Style
		x:Key="DefaultTableViewTextBlockStyle"
		BasedOn="{StaticResource BodyTextBlockStyle}"
		TargetType="TextBlock">
		<Style.Setters>
			<Setter Property="TextTrimming" Value="CharacterEllipsis" />
			<Setter Property="TextWrapping" Value="NoWrap" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Padding" Value="16,0,16,0" />
		</Style.Setters>
	</Style>

	<Style
		x:Key="DefaultTableViewTextBoxStyle"
		BasedOn="{StaticResource DefaultTextBoxStyle}"
		TargetType="TextBox">
		<Style.Setters>
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Padding" Value="15,6,5,6" />
		</Style.Setters>
	</Style>

</ResourceDictionary>
